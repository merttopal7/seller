# ── Secrets (generate with: openssl rand -base64 48) ─────────────────────────
JWT_SECRET=replace-with-random-64-char-string
NEXTAUTH_SECRET=replace-with-another-random-64-char-string

# ── Public domain (no trailing slash) ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXTAUTH_URL=https://yourdomain.com
NEXT_PUBLIC_BACKEND_URL=https://yourdomain.com

# ── App branding ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=MarketPlace

# ── Do not edit — set automatically by docker-compose.prod.yml ───────────────
# ELASTICSEARCH_URL=http://elasticsearch:9200   (injected by compose)
# DATABASE_URL=file:/app/data/prod.db           (injected by compose)
# BACKEND_API_URL=http://backend:5000           (injected by compose for frontend)
# BACKEND_URL=https://yourdomain.com            (used by upload route for image URLs)
